# syntax=docker/dockerfile:1

FROM artifacts.developer.gov.bc.ca/docker-remote/node:20-bookworm-slim AS builder

WORKDIR /usr/src/app

# CRA needs devDependencies for the production build.
# This repo's lockfile is not fully aligned with package.json, so use
# npm install with legacy peer dependency resolution for compatibility.
COPY package*.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm install --legacy-peer-deps --no-audit --no-fund && \
    npm cache clean --force

COPY . .

# Avoid CI-mode warning escalation during the static bundle build.
ENV CI=false
RUN npm run build

FROM artifacts.developer.gov.bc.ca/docker-remote/nginx:1.29.6

COPY nginx.conf /etc/nginx/nginx.conf
COPY --from=builder /usr/src/app/build /usr/share/nginx/html

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD test -f /usr/share/nginx/html/index.html || exit 1

ENTRYPOINT ["nginx"]
CMD ["-g", "daemon off;"]
